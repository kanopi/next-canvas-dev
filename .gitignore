.ddev/import-files/
.ddev/providers/*.example
.ddev/db_snapshots
.ddev/mutagen/
.ddev/apache/.gitignore
.ddev/nginx_full/.gitignore
.ddev/traefik/

# Keys (recipe regenerates)
/keys/

# Misc
.DS_Store
.idea/
.vscode/
